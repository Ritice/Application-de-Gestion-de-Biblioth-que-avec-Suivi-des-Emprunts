package cm.netconsulting.emprunt_service.service.client;


import cm.netconsulting.emprunt_service.response.Response;
import org.springframework.cloud.openfeign.FeignClient;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;

@FeignClient(
        name = "utilisateur-client",
        url  = "${services.utilisateur-url}"
)
public interface UtilisateurClient {

    // Vérifie que l'utilisateur existe et retourne ses infos
    @GetMapping("/api/v1/utilisateurs/{id}")
    Response<UtilisateurDTO> getUtilisateur(@PathVariable("id") Long id);
}
